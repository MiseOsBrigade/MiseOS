{
  "name": "miseos-repo-steward",
  "version": "0.1.0",
  "private": true,
  "description": "Governed autonomous repository maintenance for GitHub teams.",
  "packageManager": "pnpm@9.15.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "steward": "tsx packages/cli/src/index.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.8.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
