{
  "name": "shimeji-brigade-v9",
  "version": "9.0.0",
  "private": true,
  "description": "Unified production monorepo for reference-backed Shimeji character production, validation, runtime preview, and Mint bridge metadata.",
  "packageManager": "pnpm@9.15.4",
  "engines": {"node": ">=20.11.0"},
  "scripts": {
    "validate": "node tools/validate-sprite-packs.mjs",
    "build:packs": "node tools/build-runtime-packs.mjs",
    "build:metadata": "node tools/export-mint-metadata.mjs",
    "build:previews": "node tools/build-preview-sheets.mjs",
    "build": "pnpm validate && pnpm build:packs && pnpm build:metadata",
    "test": "node --test tests/*.test.mjs",
    "check": "pnpm test && pnpm build",
    "dev": "pnpm --filter @shimeji/runtime-preview dev"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "archiver": "^7.0.1",
    "pngjs": "^7.0.0"
  }
}
